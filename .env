# 这个文件用于安装前默认值和旧版本兼容。
# 安装完成后的本机安装状态以 resources/install-state.yaml 为主；
# 长期维护的代理偏好请放在 config/ 目录，不建议把 .env 纳入配置 git。

# 安装内核 可选：mihomo、clash
KERNEL_NAME=mihomo

# 安装路径
CLASH_BASE_DIR=~/clashctl

# 机场订阅（可选；留空则在安装结束后交互输入）
CLASH_CONFIG_URL=""

# 下载依赖包超时时间（秒）
CLASHCTL_DOWNLOAD_TIMEOUT=60

# 下载订阅时的 UserAgent
CLASH_SUB_UA=clash-verge/v2.4.0

# 下载订阅超时时间（秒）
CLASHCTL_SUB_TIMEOUT=5

# 默认运行托管模式：tmux、nohup、systemd
# clashon 可通过 --mode 临时选择本次托管模式；systemd 需要 root 或 sudo，且支持 Tun。
INIT_TYPE=tmux

# Web UI 压缩包
ZIP_UI=resources/zip/dist.zip

# github 加速
URL_GH_PROXY=https://gh-proxy.org

# 公共 Web 控制台
URL_CLASH_UI=http://board.zash.run.place

# 软件版本号；留空时安装脚本会通过 GitHub releases/latest 自动解析最新 tag。
# 网络受限或希望可复现安装时，建议像下面这样固定版本。
VERSION_MIHOMO=v1.19.17
VERSION_YQ=v4.49.2
VERSION_SUBCONVERTER=v0.9.0

# subconverter 来源
SUBCONVERTER_REPO=tindy2013/subconverter
